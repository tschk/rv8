+/// Spawn a thread to forward IPC messages
+fn spawn_ipc_forwarder<T: serde::Serialize + for<'de> serde::Deserialize<'de> + Send + 'static, F: FnMut(T) -> bool + Send + 'static>(
+    rx: IpcReceiver<T>,
+    mut handler: F,
+) -> std::thread::JoinHandle<()> {
+    std::thread::spawn(move || {
+        while let Ok(msg) = rx.recv() {
+            if !handler(msg) {
+                break;
+            }
+        }
+    })
+}
